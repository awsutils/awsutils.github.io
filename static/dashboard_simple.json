      "properties": {
        "metrics": [
          [
            {
              "expression": "SUM(SEARCH('{AWS/ApplicationELB,LoadBalancer,TargetGroup} MetricName=\"HTTPCode_Target_2XX_Count\"', 'Sum', 60))",
