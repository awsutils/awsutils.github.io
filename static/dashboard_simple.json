  "widgets": [
    {
      "type": "metric",
      "x": 0,
      "y": 0,
      "width": 6,
      "height": 6,
      "properties": {
        "metrics": [
          [
            {
              "expression": "FILL(SEARCH('{AWS/ApplicationELB,LoadBalancer} MetricName=\"HTTPCode_ELB_5XX_Count\"', 'Sum', 60), 0)",
              "id": "alb_elb_5xx",
              "label": "ALB ELB 5XX",
              "region": "us-east-1"
            }
          ],
          [
            {
              "expression": "FILL(SEARCH('{AWS/ApplicationELB,LoadBalancer,TargetGroup} MetricName=\"HTTPCode_Target_5XX_Count\"', 'Sum', 60), 0)",
              "id": "alb_target_5xx",
              "label": "ALB Target 5XX",
              "region": "us-east-1"
            }
          ],
          [
            {
              "expression": "FILL(SEARCH('{AWS/NetworkELB,LoadBalancer,TargetGroup} MetricName=\"HTTPCode_Target_5XX_Count\"', 'Sum', 60), 0)",
              "id": "nlb_5xx",
              "label": "NLB 5XX",
              "region": "us-east-1"
            }
          ],
          [
            {
              "expression": "FILL(SEARCH('{AWS/ApiGateway,ApiId,Stage} MetricName=\"5XXError\"', 'Sum', 60), 0)",
              "id": "apigw_5xx",
              "label": "API GW 5XX",
              "region": "us-east-1"
            }
          ],
          [
            {
              "expression": "FILL(SEARCH('{AWS/CloudFront,DistributionId,Region} MetricName=\"5xxErrorRate\"', 'p99', 60), 0)",
              "id": "cf_5xx_rate",
              "label": "CloudFront 5XX Rate (%)",
              "region": "us-east-1"
            }
          ],
          [
            {
              "expression": "FILL(SEARCH('{AWS/VpcLattice,Service,TargetGroup} MetricName=\"HTTPCode_Target_5XX_Count\"', 'Sum', 60), 0)",
              "id": "lattice_5xx",
              "label": "Lattice 5XX",
              "region": "us-east-1"
            }
          ],
          [
            {
              "expression": "FILL(SEARCH('{AWS/Lambda,FunctionName} MetricName=\"Errors\"', 'Sum', 60), 0)",
              "id": "lambda_errors",
              "region": "us-east-1",
              "label": "Lambda Errors"
            }
          ]
        ],
        "view": "timeSeries",
        "region": "us-east-1",
        "title": "🚦 5XX Errors + Lambda Error Rate",
        "period": 60,
        "liveData": false,
        "legend": {
          "position": "hidden"
        },
        "stat": "p99"
      }
    },
